# ─── API Keys ───────────────────────────────────────────────
# At least one is needed for cloud LLM features.
# Leave blank to use local-only mode (TinyLlama).

GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Model Configuration ──────────────────────────────────
# Path to local GGUF model (default: models/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf)
# MODEL_PATH=models/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf

# ─── Embedding Configuration ──────────────────────────────
# EMBEDDING_MODEL=all-MiniLM-L6-v2
